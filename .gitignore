# =========================
# Estrategia general
# =========================
# Ignorar casi todo Vivado/Vitis por defecto
Vivado_chip_design/**
Vivado_dataproc_design/**

# =========================
# Permitir estructura base
# =========================
!Vivado_chip_design/
!Vivado_chip_design/create_project.tcl
!Vivado_chip_design/hw/
!Vivado_chip_design/sw/

!Vivado_dataproc_design/
!Vivado_dataproc_design/create_project.tcl
!Vivado_dataproc_design/hw/
!Vivado_dataproc_design/sw/

# =========================
# Vivado_chip_design - HW esencial
# =========================
!Vivado_chip_design/hw/System.tcl

!Vivado_chip_design/hw/my_ip_repo/
!Vivado_chip_design/hw/my_ip_repo/**

!Vivado_chip_design/hw/ADC_DAC.srcs/
!Vivado_chip_design/hw/ADC_DAC.srcs/constrs_1/
!Vivado_chip_design/hw/ADC_DAC.srcs/constrs_1/new/
!Vivado_chip_design/hw/ADC_DAC.srcs/constrs_1/new/*.xdc

!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/
!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/bd/
!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/bd/System/
!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/bd/System/System.bd

# Opcional: permitir .xci del BD si el Tcl los necesita
!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/bd/System/ip/
!Vivado_chip_design/hw/ADC_DAC.srcs/sources_1/bd/System/ip/**/*.xci

# =========================
# Vivado_dataproc_design - HW esencial
# =========================
!Vivado_dataproc_design/hw/System.tcl

!Vivado_dataproc_design/hw/TFM_DP_part.srcs/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/constrs_1/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/constrs_1/new/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/constrs_1/new/*.xdc

!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/bd/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/bd/system1/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/bd/system1/system1.bd

# Opcional: permitir .xci del BD si el Tcl los necesita
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/bd/system1/ip/
!Vivado_dataproc_design/hw/TFM_DP_part.srcs/sources_1/bd/system1/ip/**/*.xci

# =========================
# Sources C que quieres conservar
# =========================
!Vivado_chip_design/sw/core_app/
!Vivado_chip_design/sw/core_app/src/
!Vivado_chip_design/sw/core_app/src/**

!Vivado_dataproc_design/sw/dma_fft/
!Vivado_dataproc_design/sw/dma_fft/src/
!Vivado_dataproc_design/sw/dma_fft/src/**

